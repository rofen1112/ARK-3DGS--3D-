{
  "name": "ark-3dgs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:gaussian": "node scripts/test-gaussian-parser.mjs",
    "validate:manifest": "node scripts/validate-scene-manifest.mjs",
    "validate:runtime-metadata": "node scripts/validate-runtime-gaussian-metadata.mjs",
    "validate:runtime-formats": "node scripts/validate-first-party-runtime-formats.mjs",
    "validate:renderable-assets": "node scripts/validate-first-party-renderable-assets.mjs",
    "validate:full-scene-candidate": "node scripts/validate-first-party-full-scene-candidate.mjs",
    "validate:packed-data": "node scripts/audit-packed-gaussian-data.mjs",
    "validate:packed-data:source": "node scripts/audit-packed-gaussian-data.mjs public/scenes/demo_room_001/gaussian/scene.ply public/scenes/demo_room_001/meta/packed_gaussian_source_data_audit_report.json 2048",
    "validate:ply": "node scripts/validate-gaussian-ply.mjs",
    "prepare:ply-preview": "node scripts/create-gaussian-ply-preview.mjs",
    "assets:pull:hf": "node scripts/pull-hf-assets.mjs",
    "qa:visual": "node scripts/cdp-screenshot.mjs http://127.0.0.1:5173/?autoload=1 artifacts/visual-qa.png 60000",
    "qa:formats": "node scripts/qa-format-matrix.mjs",
    "qa:baseline": "node scripts/qa-baseline-compare.mjs",
    "qa:independent": "node scripts/qa-independent-compare.mjs",
    "qa:first-party": "node scripts/qa-first-party-preview.mjs",
    "qa:first-party-gaussian": "node scripts/qa-first-party-gaussian.mjs",
    "qa:first-party-compare": "node scripts/qa-first-party-gaussian-compare.mjs",
    "qa:first-party-same-camera": "node scripts/qa-first-party-same-camera-compare.mjs",
    "qa:first-party-pipeline-isolation": "node scripts/qa-first-party-same-camera-compare.mjs public/scenes/demo_room_001/meta/first_party_pipeline_isolation_report.json artifacts/first-party-pipeline-isolation 420000 --pipeline-core",
    "qa:first-party-pipeline-isolation:preview": "node scripts/qa-first-party-same-camera-compare.mjs public/scenes/demo_room_001/meta/first_party_pipeline_isolation_preview_report.json artifacts/first-party-pipeline-isolation-preview 120000 --asset=ply-preview --pipeline-isolation",
    "qa:first-party-pipeline-isolation:exhaustive": "node scripts/qa-first-party-same-camera-compare.mjs public/scenes/demo_room_001/meta/first_party_pipeline_isolation_exhaustive_report.json artifacts/first-party-pipeline-isolation-exhaustive 420000 --pipeline-isolation",
    "qa:first-party-data-texture": "node scripts/qa-first-party-data-texture-audit.mjs",
    "qa:first-party-texture-fetch": "node scripts/qa-first-party-texture-fetch-renderer.mjs",
    "qa:first-party-texture-fetch-compare": "node scripts/qa-first-party-same-camera-compare.mjs public/scenes/demo_room_001/meta/first_party_texture_fetch_compare_report.json artifacts/first-party-texture-fetch-compare 180000 --asset=ply-preview --texture-fetch",
    "qa:first-party-stress": "node scripts/qa-first-party-gaussian-stress.mjs",
    "qa:first-party-full-scene-smoke": "node scripts/qa-first-party-full-scene-source-ply-smoke.mjs",
    "qa:first-party-local-source-smoke": "node scripts/qa-first-party-local-source-ply-smoke.mjs",
    "qa:first-party-full-scene-visual": "node scripts/qa-first-party-full-scene-visual-budget.mjs",
    "qa:first-party-full-scene-performance": "node scripts/qa-first-party-full-scene-performance-budget.mjs",
    "qa:first-party-readiness": "node scripts/qa-first-party-default-readiness.mjs"
  },
  "dependencies": {
    "@manycore/aholo-viewer": "^1.2.9"
  },
  "devDependencies": {
    "@mkkellogg/gaussian-splats-3d": "^0.4.7",
    "@types/three": "^0.177.0",
    "three": "^0.177.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
